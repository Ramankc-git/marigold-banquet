# Admin credentials (used as fallback when database is unavailable, e.g. Vercel)
ADMIN_PASSWORD="admin123"
MANAGER_PASSWORD="manager123"
EDITOR_PASSWORD="editor123"

# Email / Nodemailer
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="info@marigoldbanquet.com.np"

# eSewa Payment Gateway
ESEWA_MERCHANT_ID=""
ESEWA_SECRET_KEY=""
ESEWA_SUCCESS_URL="http://localhost:3000/api/payment/esewa/success"
ESEWA_FAILURE_URL="http://localhost:3000/api/payment/esewa/failure"

# Khalti Payment Gateway
