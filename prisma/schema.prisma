// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("content_editor") // super_admin, event_manager, content_editor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  eventType       String
  hallPreference  String?
  expectedGuests  Int?
  preferredDate   String?
  budgetRange     String?
  specialReqs     String?
  status          String   @default("new") // new, contacted, confirmed, cancelled
  referenceNumber String   @unique
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  eventType       String
  hallId          String?
  expectedGuests  Int?
  eventDate       String
  startTime       String?
  endTime         String?
  packageType     String?
  totalAmount     Float?
  status          String   @default("pending") // pending, confirmed, cancelled, completed
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  hall            Hall?    @relation(fields: [hallId], references: [id])
}

model Hall {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  capacityBanquet Int?
  capacityTheatre Int?
  capacityCocktail Int?
  dimensionsSqft Int?
  features      String   // JSON string of features
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bookings      Booking[]
  photos        HallPhoto[]
}

model HallPhoto {
  id        String   @id @default(cuid())
  hallId    String
  url       String
  caption   String?
  isDecorated Boolean @default(false)
  order     Int      @default(0)
  hall      Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

model Package {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String   // wedding, party, corporate
  tier        String   // silver, gold, platinum, basic, premium, luxury
  description String
  price       Float?
  priceUnit   String?  // per_plate, per_event, half_day, full_day
  includes    String   // JSON string of included items
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // nepali_thali, indian, chinese, continental, fusion, buffet, live_counters
  description String?
  pricePerPlate Float?
  isVegetarian Boolean @default(false)
  isJain      Boolean  @default(false)
  isHalal     Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DecorationTheme {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String   // royal, floral, minimalist, traditional_nepali, modern_glam, rustic, garden
  tier        String   // basic, premium, luxury
  description String
  includes    String   // JSON string
  price       Float?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photos      DecorationPhoto[]
}

model DecorationPhoto {
  id        String             @id @default(cuid())
  themeId   String
  url       String
  caption   String?
  isBefore Boolean            @default(false)
  order     Int                @default(0)
  theme     DecorationTheme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  category  String   // weddings, parties, corporate, decoration, food, venue_spaces
  eventDate String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryVideo {
  id          String   @id @default(cuid())
  youtubeUrl  String
  title       String
  category    String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  featuredImage String?
  category      String   // wedding_tips, party_ideas, corporate_events, decoration_trends, food_catering, venue_guide, nepal_event_culture
  author        String?
  readTime      Int?
  seoTitle      String?
  seoDesc       String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  clientName String
  eventType String
  rating    Int      @default(5)
  review    String
  photo     String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String
  discount    String?
  startDate   String?
  endDate     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  category    String   // photographer, caterer, decorator, band, mehendi, makeup, transport
  description String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?
  photo     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   // booking, catering, decoration, weddings, corporate, pricing
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model BlockedDate {
  id        String   @id @default(cuid())
  hallId    String?
  date      String
  reason    String?
  createdAt DateTime @default(now())
}

model PageSetting {
  id        String   @id @default(cuid())
  pageKey   String   @unique
  isActive  Boolean  @default(true)
  sections  String   @default("{}") // JSON for section visibility/order
}
